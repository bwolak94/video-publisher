{
  "name": "core-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "test": "jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json --runInBand",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "@aws-sdk/lib-storage": "^3.1075.0",
    "@aws-sdk/s3-request-presigner": "^3.1075.0",
    "@bull-board/api": "^8.0.1",
    "@bull-board/fastify": "^8.0.1",
    "@bull-board/nestjs": "^8.0.1",
    "@fastify/static": "^8.0.0",
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-fastify": "^10.4.0",
    "@nestjs/platform-socket.io": "^10.4.0",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/websockets": "^10.4.0",
    "@remotion/lambda": "^4.0.482",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/nodemailer": "^8.0.1",
    "bullmq": "^5.12.0",
    "drizzle-orm": "^0.33.0",
    "fluent-ffmpeg": "^2.1.3",
    "googleapis": "^173.0.0",
    "ioredis": "^5.4.1",
    "nodemailer": "^9.0.1",
    "pg": "^8.12.0",
    "pino": "^9.3.2",
    "pino-http": "^10.2.0",
    "prom-client": "^15.1.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "reflect-metadata": "^0.2.2",
    "remotion": "^4.0.482",
    "rxjs": "^7.8.1",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@nestjs/testing": "^10.4.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.5.0",
    "@types/pg": "^8.11.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^6.0.2",
    "drizzle-kit": "^0.24.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts",
      "tsx"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.tsx?$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest",
      "^.+\\.tsx$": [
        "ts-jest",
        {
          "tsconfig": {
            "jsx": "react-jsx"
          }
        }
      ]
    },
    "collectCoverageFrom": [
      "**/*.(t|j)sx?"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
