{
  "title": "AI Video Factory",
  "uid": "ai-video-factory",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "Pipeline Jobs / sec",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(pipeline_jobs_total[1m])",
          "legendFormat": "{{queue}} / {{status}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Queue Depth",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "queue_depth",
          "legendFormat": "{{queue}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Job Duration p95 (seconds)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(pipeline_job_duration_seconds_bucket[5m]))",
          "legendFormat": "p95 {{queue}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "External API Duration p95 (seconds)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(external_api_duration_seconds_bucket[5m]))",
          "legendFormat": "p95 {{service}} {{endpoint}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "External API Errors / sec",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(external_api_errors_total[1m])",
          "legendFormat": "{{service}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Cache Hit Ratio",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 16, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(cache_hits_total[1m]) / (rate(cache_hits_total[1m]) + rate(cache_misses_total[1m]))",
          "legendFormat": "{{cache}}"
        }
      ]
    },
    {
      "id": 7,
      "title": "API Cost USD / hour",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 16, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(api_cost_usd_total[1h]) * 3600",
          "legendFormat": "{{service}}"
        }
      ]
    },
    {
      "id": 8,
      "title": "Active WebSocket Connections",
      "type": "stat",
      "gridPos": { "x": 0, "y": 24, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "active_websocket_connections",
          "legendFormat": "connections"
        }
      ]
    },
    {
      "id": 9,
      "title": "DLQ Depth",
      "type": "stat",
      "gridPos": { "x": 6, "y": 24, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "dlq_depth",
          "legendFormat": "{{queue}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      }
    }
  ]
}
