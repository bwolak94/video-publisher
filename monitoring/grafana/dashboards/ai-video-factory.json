{
  "title": "AI Video Factory",
  "uid": "ai-video-factory",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "title": "Pipeline Jobs / sec",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "rate(pipeline_jobs_total[1m])",
          "legendFormat": "{{queue}} / {{status}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Queue Depth",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "queue_depth",
          "legendFormat": "{{queue}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Job Duration p95 (seconds)",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(pipeline_job_duration_seconds_bucket[5m]))",
          "legendFormat": "p95 {{queue}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "External API Duration p95 (seconds)",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(external_api_duration_seconds_bucket[5m]))",
          "legendFormat": "p95 {{service}} {{endpoint}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "External API Errors / sec",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 8,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "rate(external_api_errors_total[1m])",
          "legendFormat": "{{service}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Cache Hit Ratio",
      "type": "timeseries",
      "gridPos": {
        "x": 8,
        "y": 16,
        "w": 8,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "rate(cache_hits_total[1m]) / (rate(cache_hits_total[1m]) + rate(cache_misses_total[1m]))",
          "legendFormat": "{{cache}}"
        }
      ]
    },
    {
      "id": 7,
      "title": "API Cost USD / hour",
      "type": "timeseries",
      "gridPos": {
        "x": 16,
        "y": 16,
        "w": 8,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "rate(api_cost_usd_total[1h]) * 3600",
          "legendFormat": "{{service}}"
        }
      ]
    },
    {
      "id": 8,
      "title": "Active WebSocket Connections",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 24,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "active_websocket_connections",
          "legendFormat": "connections"
        }
      ]
    },
    {
      "id": 9,
      "title": "DLQ Depth",
      "type": "stat",
      "gridPos": {
        "x": 6,
        "y": 24,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "dlq_depth",
          "legendFormat": "{{queue}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 5
              },
              {
                "color": "red",
                "value": 10
              }
            ]
          }
        }
      }
    },
    {
      "id": 10,
      "title": "Video Provider \u2014 Requests / sec",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 28,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "sum by (provider, status) (rate(video_provider_requests_total[5m]))",
          "legendFormat": "{{provider}} \u2014 {{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 11,
      "title": "Video Provider \u2014 Generation Duration p95 (seconds)",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 28,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 2
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (provider, le) (rate(video_provider_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{provider}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 12,
      "title": "Video Provider \u2014 Fallbacks / min",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 36,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "sum by (from_provider, to_provider) (increase(video_provider_fallback_total[1m]))",
          "legendFormat": "{{from_provider}} \u2192 {{to_provider}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 13,
      "title": "Video Provider \u2014 Success Rate %",
      "type": "stat",
      "gridPos": {
        "x": 12,
        "y": 36,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 80
              },
              {
                "color": "green",
                "value": 95
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "auto",
        "colorMode": "background"
      },
      "targets": [
        {
          "expr": "100 * sum by (provider) (rate(video_provider_requests_total{status=\"success\"}[5m])) / sum by (provider) (rate(video_provider_requests_total[5m]))",
          "legendFormat": "{{provider}}",
          "refId": "A"
        }
      ]
    }
  ]
}